{
  "name": "mindflow",
  "version": "0.1.0",
  "description": "AI-Native Project Management with Buddy Mesh",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "dev:web": "bunx serve web",
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun run src/server/index.ts",
    "start:all": "bun run dev & bun run dev:web",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "project-management",
    "ai-native",
    "buddy-mesh",
    "multi-agent",
    "outcomes",
    "productivity"
  ],
  "author": "Alpha Team",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^6.17.0"
  }
}
